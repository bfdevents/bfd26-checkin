```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BFD26 Brisbane Check-In</title>

<style>
body{
    font-family: Arial, sans-serif;
    text-align:center;
    margin-top:50px;
    background:#f9f9f9;
}

.logo{
    max-width:180px;
    margin-bottom:20px;
}

input,
button{
    padding:12px;
    margin:10px;
    width:240px;
    border-radius:6px;
    border:1px solid #ccc;
    font-size:16px;
}

button{
    background:#3498db;
    color:white;
    border:none;
    cursor:pointer;
}

button:hover{
    opacity:0.9;
}

#paused{
    padding:40px;
}

#status{
    margin-top:15px;
}
</style>
</head>

<body>

<div id="paused" style="display:none;"></div>

<div id="app">

    <img
        class="logo"
        src="https://242329549.fs1.hubspotusercontent-na2.net/hubfs/242329549/crm-properties-file-values/BFD26%20FINAL%20Logo.png"
        alt="BFD26 Logo"
    >

    <h1>BFD26 Brisbane Check-In</h1>
    <h2>May 30, 2026</h2>

    <form id="form">

        <input
            type="text"
            id="fname"
            placeholder="First Name"
            required
        >

        <input
            type="text"
            id="lname"
            placeholder="Last Name"
            required
        >

        <br>

        <button type="submit">
            Continue
        </button>

    </form>

    <p id="status"></p>

</div>

<script>

// ======================================
// CONFIG
// ======================================

const webhookURL = "https://hook.eu1.make.com/dspa2fhez2mfqyttv84fdb6hf6gejz4q";

const event = {
    day: 1,
    date: "2026-05-30",
    startHour: 7,
    endHour: 14
};

// ======================================
// DATE / TIME HELPERS
// ======================================

function getBrisbaneNow(){

    return new Date(
        new Date().toLocaleString(
            "en-US",
            { timeZone: "Australia/Brisbane" }
        )
    );

}

function getTodayString(date){

    return date.toLocaleDateString(
        "en-CA",
        { timeZone: "Australia/Brisbane" }
    );

}

function getMinutes(date){

    return (date.getHours() * 60) + date.getMinutes();

}

function formatDate(dateStr){

    const [year, month, day] = dateStr.split("-");

    return new Date(year, month - 1, day)
        .toLocaleDateString("en-AU", {
            year: "numeric",
            month: "long",
            day: "numeric"
        });

}

function formatTime(hour){

    const suffix = hour >= 12 ? "PM" : "AM";
    const h12 = hour % 12 || 12;

    return `${h12}:00 ${suffix}`;

}

// ======================================
// ACCESS CONTROL
// ======================================

function checkAccess(){

    const app = document.getElementById("app");
    const paused = document.getElementById("paused");

    app.style.display = "none";
    paused.style.display = "none";

    const now = getBrisbaneNow();

    const today = getTodayString(now);

    const currentMinutes = getMinutes(now);

    const startMinutes = event.startHour * 60;
    const endMinutes = event.endHour * 60;

    // Wrong date
    if(today !== event.date){

        blockScreen(
            `Check-in will be available on ${formatDate(event.date)} from ${formatTime(event.startHour)} to ${formatTime(event.endHour)} Brisbane time.`
        );

        return;
    }

    // Outside check-in window
    if(
        currentMinutes < startMinutes ||
        currentMinutes >= endMinutes
    ){

        blockScreen(
            `Check-in is available from ${formatTime(event.startHour)} to ${formatTime(event.endHour)} Brisbane time.`
        );

        return;
    }

    // Allowed
    app.style.display = "block";

}

function blockScreen(message){

    const paused = document.getElementById("paused");

    paused.style.display = "block";

    paused.innerHTML = `
        <h1>We’re currently between sessions.</h1>

        <h3>We’ll be ready to greet you soon!</h3>

        <p>${message}</p>
    `;

}

// ======================================
// FORM SUBMIT
// ======================================

document
    .getElementById("form")
    .addEventListener("submit", async (e)=>{

    e.preventDefault();

    const fname = document
        .getElementById("fname")
        .value
        .trim();

    const lname = document
        .getElementById("lname")
        .value
        .trim();

    if(!fname || !lname){

        alert("Please enter your name.");

        return;
    }

    document.getElementById("status")
        .textContent = "Submitting...";

    try{

        const response = await fetch(
            webhookURL,
            {
                method:"POST",

                headers:{
                    "Content-Type":"application/json"
                },

                body: JSON.stringify({

                    fname,
                    lname,

                    day: event.day,

                    action: "check-in",

                    timestamp_utc: new Date().toISOString()

                })
            }
        );

        if(!response.ok){
            throw new Error("Webhook failed");
        }

        document.body.innerHTML = `
            <div style="margin-top:80px;">
                <h1>Check-In Complete</h1>

                <p>
                    Thank you
                    <strong>${fname} ${lname}</strong>!
                </p>
            </div>
        `;

    }catch(error){

        console.error(error);

        alert("Something went wrong. Please try again.");

        document.getElementById("status")
            .textContent = "";
    }

});

// ======================================
// START
// ======================================

checkAccess();

setInterval(checkAccess, 30000);

</script>

</body>
</html>
